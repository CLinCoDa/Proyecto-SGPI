# ==========================================
# 1. BACKEND (Django & Python)
# ==========================================
# Entornos virtuales
venv/
.venv/
env/
ENV/

# Archivos de Python (Cache y compilados)
__pycache__/
*.py[cod]
*$py.class
*.so

# Base de datos (SQLite)
db.sqlite3
*.db

# Django local (Seguridad y archivos temporales)
.env
.env.local
local_settings.py
/media/
/staticfiles/

# Celery y Logs
celerybeam-schedule
celerybeat.pid
*.log

# ==========================================
# 2. FRONTEND (React + Vite)
# ==========================================
# Dependencias (LA MÁS PESADA, no la subas)
node_modules/

# Build de producción de Vite
dist/
dist-ssr/

# Archivos de log de NPM/Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Variables de entorno de React
.env.development.local
.env.test.local
.env.production.local
.env.local

# TypeScript (si usas TS, ignora el archivo de build info)
*.tsbuildinfo

# ==========================================
# 3. HERRAMIENTAS Y SISTEMA
# ==========================================
# Editores (VS Code, PyCharm, etc.)
.vscode/
.idea/
*.swp
*.swo

# Archivos de sistema (Mac y Windows)
.DS_Store
Thumbs.db

# Cobertura de tests
.pytest_cache/
.coverage
htmlcov/